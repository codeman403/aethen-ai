# Aethen-AI Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── LLM Providers ──────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=

# ── Vector DB (pgvector — built into Postgres, no external service needed) ─
USE_PGVECTOR=true

# ── Graph DB (Neo4j Aura) ─────────────────────────
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Langfuse (Live Trace Ingestion) ────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Cron secret (shared between Vercel cron and backend) ───────────────
CRON_SECRET=

# ── Sentry Error Monitoring ────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=production

# ── Transactional Email (Resend) ───────────────────
RESEND_API_KEY=
EMAIL_FROM=

# ── App Config ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
LOG_LEVEL=INFO

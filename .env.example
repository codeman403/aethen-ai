# Aethen-AI Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── LLM Providers ──────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=

# ── Vector DB (Pinecone) ──────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=aethen-traces

# ── Graph DB (Neo4j Aura) ─────────────────────────
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── App Config ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
LOG_LEVEL=INFO

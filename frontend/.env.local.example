# Frontend environment variables — copy to .env.local and fill in values
# .env.local is gitignored

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Aethen API key — generated in Settings → Integrations → API Key
# Required once you generate a key via the UI
NEXT_PUBLIC_AETHEN_API_KEY=your-aethen-api-key-here

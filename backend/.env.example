# Aethen-AI Backend — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── LLM Providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=

# DataExpert.io proxy base URLs (leave blank to use provider defaults)
ANTHROPIC_BASE_URL=
OPENAI_BASE_URL=

# ── Session Store: PostgreSQL / Supabase ───────────────────────────────────
# Supabase: dashboard → project → Settings → Database → Connection string (URI)
# Use "Session mode" pooler (port 5432) or the direct connection.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── Vector DB: Pinecone ────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=aethen-traces

# ── Graph DB: Neo4j Aura — graph traversal only ────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Live Trace Ingestion: Langfuse ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── App Config ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
DEBUG=false
